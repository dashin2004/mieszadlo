    <EventBinding id="HMIMainContent.MieszanieButton.Click">
      <Source xsi:type="widgets.brease.Button.Event" contentRefId="HMIMainContent" widgetRefId="MieszanieButton" event="Click" />
      <EventHandler>
        <Action>
          <Target xsi:type="opcUa.NodeAction" refId="::Tanks:MieszanieBtn">
            <Method xsi:type="opcUa.NodeAction.ToggleValueBool" />
          </Target>
        </Action>
      </EventHandler>
    </EventBinding>
  </Bindings>
</EventBindingSet>