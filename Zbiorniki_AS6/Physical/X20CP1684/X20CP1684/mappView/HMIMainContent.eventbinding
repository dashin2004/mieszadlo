        </Action>
      </EventHandler>
    </EventBinding>
    <EventBinding id="HMIMainContent.Zb2ZaworButton.Click">
      <Source xsi:type="widgets.brease.Button.Event" contentRefId="HMIMainContent" widgetRefId="Zb2ZaworButton" event="Click" />
      <EventHandler>
        <Action>
          <Target xsi:type="opcUa.NodeAction" refId="::Tanks:Zb2_zawor_view">
            <Method xsi:type="opcUa.NodeAction.ToggleValueBool" />
          </Target>
        </Action>
      </EventHandler>
    </EventBinding>
    <EventBinding id="HMIMainContent.Button4.Click">
